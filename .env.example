# AI Gateway Configuration (required)
AI_GATEWAY_API_KEY=your-api-key
AI_GATEWAY_BASE_URL=your-gateway-url

# Model (optional, defaults to @makers/deepseek-v4-flash)
# AI_GATEWAY_MODEL=@makers/deepseek-v4-flash

# ─── Customization (optional) ────────────────────────────────────────────────
# SYSTEM_PROMPT=You are a helpful assistant for my blog.
# ASSISTANT_NAME=AI Assistant
# WELCOME_MESSAGE=Hi! How can I help you today?

# ─── Layer B: Site Knowledge Base (optional) ─────────────────────────────────
# Set this to enable full-site search via sitemap crawling.
# SITEMAP_URL=https://myblog.com/sitemap.xml

# ─── Layer C: Business API Integration (optional) ────────────────────────────
# Provide your REST API schema so the AI can query your backend in real time.
# DATA_API_BASE_URL=https://myblog.com/api
# DATA_API_KEY=your-api-key
# DATA_API_SCHEMA_URL=https://myblog.com/api/ai-schema.json
